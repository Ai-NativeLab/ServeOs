{
  "name": "pos",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.node.json && vite build && electron-builder",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run"
  },
  "dependencies": {},
  "optionalDependencies": {
    "//": "Parked with the offline store in electron/_offline. Optional so a failed native build never blocks `npm install`.",
    "better-sqlite3": "^11.8.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.29.0",
    "@vitejs/plugin-react": "^4.3.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/better-sqlite3": "^7.6.11",
    "tailwindcss": "^4.3.2",
    "@tailwindcss/vite": "^4.3.2",
    "vitest": "^4.1.8",
    "typescript": "^5"
  }
}
